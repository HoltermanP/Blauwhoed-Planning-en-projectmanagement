# --- Toegang (demo-auth; vervang later door Clerk, zie README) ---
# Wachtwoord voor AI-Group (rol: beheerder)
PORTAL_ADMIN_PASSWORD=verander-mij-aigroup
# Wachtwoord voor Blauwhoed (rol: klant)
PORTAL_CLIENT_PASSWORD=verander-mij-blauwhoed

# --- Bestandsopslag documenten (optioneel) ---
# Op Vercel: koppel via het dashboard (Storage → Blob) een Blob-store aan het
# project; Vercel zet BLOB_READ_WRITE_TOKEN dan automatisch. Zonder token worden
# uploads lokaal opgeslagen in .data/uploads/ (alleen geschikt voor development).
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_xxxxxxxx

# --- Database (optioneel) ---
# Zonder DATABASE_URL slaat het portal state lokaal op in .data/state.json (alleen dev).
# Op Vercel is een database vereist voor persistentie: maak een Neon-project aan
# en plak hier de connection string.
# DATABASE_URL=postgres://user:pass@ep-xxx.eu-central-1.aws.neon.tech/neondb?sslmode=require
